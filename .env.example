# ===== Feishu (Lark) =====
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_BOT_NAME=ComfyUI Bot

# ===== ComfyUI =====
COMFYUI_BASE_URL=http://127.0.0.1:8188
WORKFLOW_DIR=./workflows
DATA_DIR=./data
PROGRESS_INTERVAL_SECONDS=5
MAX_CONCURRENT_TASKS=1
LOG_LEVEL=INFO

# ===== Translator (optional) =====
# Auto-translates Chinese prompts to English before submission so SDXL/CLIP
# models understand them. Leave DASHSCOPE_API_KEY blank to disable.
# Get a key: https://bailian.console.aliyun.com/?tab=model#/api-key
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TRANSLATOR_MODEL=qwen-plus
